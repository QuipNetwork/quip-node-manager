{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quip-node-manager",
  "version": "0.0.0",
  "identifier": "com.piqued.quip-node-manager",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Quip Node Manager",
        "width": 900,
        "height": 700,
        "resizable": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
